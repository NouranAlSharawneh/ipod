{
  "name": "ipod",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,bridge -c cyan,magenta \"npm:dev:web\" \"npm:dev:bridge\"",
    "dev:web": "vite",
    "dev:bridge": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:bridge": "bash scripts/build-bridge.sh",
    "tauri": "tauri",
    "tauri:dev": "npm run build:bridge && tauri dev",
    "tauri:build": "npm run build:bridge && tauri build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
