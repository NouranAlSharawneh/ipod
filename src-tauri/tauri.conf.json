{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "iPod",
  "version": "0.1.0",
  "identifier": "com.nouran.ipod",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 440,
        "height": 700,
        "minWidth": 220,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "externalBin": ["binaries/ipod-bridge"],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
